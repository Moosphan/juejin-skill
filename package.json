{
  "name": "juejin-skill",
  "version": "0.1.3",
  "description": "Dual-platform Juejin skill for Codex and Claude Code",
  "type": "module",
  "private": false,
  "bin": {
    "juejin-skill": "./bin/juejin-skill.js"
  },
  "files": [
    "bin",
    "src",
    "scripts",
    ".claude",
    "agents",
    "SKILL.md",
    "README.md",
    "package-lock.json"
  ],
  "scripts": {
    "build": "node ./scripts/build-release.js",
    "check": "npm run lint && npm run test",
    "lint": "eslint .",
    "release:notes": "node ./scripts/render-release-notes.js",
    "test": "node --test",
    "release:dry-run": "node ./scripts/build-release.js --dry-run"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "dependencies": {
    "cheerio": "^1.1.0",
    "markdown-it": "^14.1.0",
    "playwright": "^1.54.1",
    "turndown": "^7.2.1",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "eslint": "^9.28.0"
  }
}
